<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>নতুন সদস্য হোন — শহীদ আইয়ুব আলী স্মৃতি সংঘ ও পাঠাগার</title>
<link rel="stylesheet" href="css/style.css" />
</head>
<body>

<div id="navRoot"></div>

<main class="wrap" style="max-width:760px;">
  <div class="page-toolbar">
    <div class="section-label">নতুন সদস্য রেজিস্ট্রেশন</div>
    <div id="refreshBtnRoot"></div>
  </div>
  <div class="panel">
    <div class="grid-2">
      <div><label>নাম</label><input id="mName" /></div>
      <div><label>বাবার নাম</label><input id="mFather" /></div>
      <div><label>মায়ের নাম</label><input id="mMother" /></div>
      <div><label>গ্রাম</label><input id="mVillage" /></div>
      <div><label>শিক্ষাগত যোগ্যতা</label><input id="mEducation" /></div>
      <div><label>ফোন নম্বর</label><input id="mPhone" /></div>
    </div>

    <label>সদস্যের ছবি</label>
    <input id="mPhoto" type="file" accept="image/*" onchange="handlePhoto(event)" />
    <img id="photoPreview" style="display:none; margin-top:10px; width:90px; height:90px; object-fit:cover; border:1px solid var(--line); border-radius:4px;" />

    <div class="grid-2">
      <div><label>চাঁদার পরিমাণ (৳)</label><input id="mFee" type="number" min="0" /></div>
      <div>
        <label>পেমেন্ট পদ্ধতি</label>
        <select id="mPayMethod" onchange="togglePayMethod()">
          <option value="cash">ক্যাশ</option>
          <option value="online">অনলাইন</option>
        </select>
      </div>
    </div>

    <div id="cashWrap">
      <label>কার কাছে জমা দিলেন</label>
      <input id="mCashReceivedBy" placeholder="যার কাছে টাকা জমা দেওয়া হয়েছে তার নাম" />
    </div>
    <div id="onlineWrap" style="display:none;">
      <div class="grid-2">
        <div><label>কোন নম্বর হতে পাঠানো হয়েছে</label><input id="mTransFrom" /></div>
        <div><label>কোন নম্বরে পাঠানো হয়েছে</label><input id="mTransTo" /></div>
      </div>
      <label>ট্রানজেকশন নম্বর</label>
      <input id="mTransactionId" placeholder="যেমন: 8N7K2X9P1Q" />
    </div>

    <button class="btn brass" style="margin-top:20px;" onclick="registerMember()">সদস্য হোন</button>
    <div id="regMsg"></div>
  </div>

  <p style="margin-top:20px; color:var(--muted); font-size:0.88rem;">
    রেজিস্ট্রেশন সম্পন্ন হলে একটা সদস্য আইডি পাবেন — সেটা দিয়েই পরবর্তীতে বই বুকিং করা যাবে। কমিটিতে পদবি (সভাপতি/সম্পাদক/লাইব্রেরিয়ান ইত্যাদি) অ্যাডমিন পরবর্তীতে <a href="committee.html" style="color:var(--brass-dark); font-weight:600;">কমিটি পাতা</a> থেকে যুক্ত করে দেবেন।
  </p>
</main>

<div id="adminModalRoot"></div>
<div class="footer">শহীদ আইয়ুব আলী স্মৃতি সংঘ ও পাঠাগার · কুলানন্দপুর, বলগাড়ী, ঘোড়াঘাট, দিনাজপুর</div>

<script src="js/config.js"></script>
<script src="js/api.js"></script>
<script>
renderNav('register.html');

function togglePayMethod() {
  const online = document.getElementById('mPayMethod').value === 'online';
  document.getElementById('cashWrap').style.display = online ? 'none' : 'block';
  document.getElementById('onlineWrap').style.display = online ? 'block' : 'none';
}

let photoDataUrl = '';
function handlePhoto(evt) {
  const file = evt.target.files[0];
  if (!file) { photoDataUrl = ''; return; }
  const reader = new FileReader();
  reader.onload = () => {
    const img = new Image();
    img.onload = () => {
      // ছবি ছোট করে (max 400px) সংরক্ষণের জন্য base64 বানানো হচ্ছে, যাতে দ্রুত আপলোড হয়
      const maxSize = 400;
      let { width, height } = img;
      if (width > height && width > maxSize) { height *= maxSize / width; width = maxSize; }
      else if (height > maxSize) { width *= maxSize / height; height = maxSize; }
      const canvas = document.createElement('canvas');
      canvas.width = width; canvas.height = height;
      canvas.getContext('2d').drawImage(img, 0, 0, width, height);
      photoDataUrl = canvas.toDataURL('image/jpeg', 0.75);
      const preview = document.getElementById('photoPreview');
      preview.src = photoDataUrl;
      preview.style.display = 'block';
    };
    img.src = reader.result;
  };
  reader.readAsDataURL(file);
}

async function registerMember() {
  const payMethod = document.getElementById('mPayMethod').value;

  const payload = {
    name: document.getElementById('mName').value.trim(),
    fatherName: document.getElementById('mFather').value.trim(),
    motherName: document.getElementById('mMother').value.trim(),
    village: document.getElementById('mVillage').value.trim(),
    education: document.getElementById('mEducation').value.trim(),
    phone: document.getElementById('mPhone').value.trim(),
    photo: photoDataUrl,
    feeAmount: document.getElementById('mFee').value || 0,
    paymentMethod: payMethod,
    cashReceivedBy: payMethod === 'cash' ? document.getElementById('mCashReceivedBy').value.trim() : '',
    transFrom: payMethod === 'online' ? document.getElementById('mTransFrom').value.trim() : '',
    transTo: payMethod === 'online' ? document.getElementById('mTransTo').value.trim() : '',
    transactionId: payMethod === 'online' ? document.getElementById('mTransactionId').value.trim() : '',
  };
  const msg = document.getElementById('regMsg');
  if (!payload.name || !payload.phone) {
    msg.innerHTML = `<div class="msg error">নাম ও ফোন নম্বর আবশ্যক</div>`;
    return;
  }
  if (payMethod === 'online' && !payload.transactionId) {
    msg.innerHTML = `<div class="msg error">অনলাইন পেমেন্টের ক্ষেত্রে ট্রানজেকশন নম্বর আবশ্যক</div>`;
    return;
  }
  msg.innerHTML = `<div class="msg success">সংরক্ষণ করা হচ্ছে...</div>`;
  const res = await Api.post('registerMember', payload);
  if (res.error) { msg.innerHTML = `<div class="msg error">${res.error}</div>`; return; }
  msg.innerHTML = `<div class="msg success">সদস্যপদ তৈরি হয়েছে। আপনার সদস্য আইডি: <strong class="mono">${res.id}</strong> — বই বুকিং এর সময় এই আইডি ব্যবহার করুন।</div>`;
  ['mName', 'mFather', 'mMother', 'mVillage', 'mEducation', 'mPhone', 'mFee', 'mCashReceivedBy', 'mTransFrom', 'mTransTo', 'mTransactionId'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('mPhoto').value = '';
  document.getElementById('photoPreview').style.display = 'none';
  photoDataUrl = '';
}
</script>
</body>
</html>
